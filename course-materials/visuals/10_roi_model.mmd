graph TB
    subgraph FORMULA["📊 Формула масштабируемости"]
        F[Output = People × Skill × Time × AI_Leverage^n]
    end
    
    subgraph HUMAN["👤 Модель: Человек"]
        H1[Стоимость: $5000/мес]
        H2[Скорость: 8 часов/день]
        H3[Масштаб: линейный]
        H4[Ошибки: 5-15%]
    end
    
    subgraph AGENT["🤖 Модель: Агент"]
        A1[Стоимость: $200/мес API]
        A2[Скорость: 24/7]
        A3[Масштаб: экспоненциальный]
        A4[Ошибки: 2-5% с контролем]
    end
    
    subgraph HYBRID["🔄 Модель: Гибрид"]
        HY1[Человек: стратегия + контроль]
        HY2[Агент: исполнение + рутина]
        HY3[Масштаб: оптимальный]
        HY4[Ошибки: минимальные]
    end
    
    FORMULA --> HUMAN
    FORMULA --> AGENT
    FORMULA --> HYBRID
    
    style FORMULA fill:#e2d9f3,stroke:#6f42c1
    style HUMAN fill:#fff3cd,stroke:#ffc107
    style AGENT fill:#cce5ff,stroke:#0d6efd
    style HYBRID fill:#d4edda,stroke:#28a745
